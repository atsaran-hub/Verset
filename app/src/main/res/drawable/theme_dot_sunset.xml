<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Taille du cercle -->
    <size
        android:width="34dp"
        android:height="34dp"/>

    <!-- Gradient identique à ton thème -->
    <gradient
        android:angle="135"
        android:startColor="#FF7A3D"
        android:centerColor="#6B5BD6"
        android:endColor="#1B1B1B"/>

    <!-- Bordure légère -->
    <stroke
        android:width="1dp"
        android:color="#22000000"/>
</shape>
