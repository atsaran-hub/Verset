<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Taille du dot -->
    <size
        android:width="34dp"
        android:height="34dp"/>

    <!-- Gradient identique à ton background -->
    <gradient
        android:angle="135"
        android:startColor="#2A2F36"
        android:centerColor="#171A1F"
        android:endColor="#0E1013"/>

    <!-- Bordure légère -->
    <stroke
        android:width="1dp"
        android:color="#22000000"/>
</shape>
