<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- CTA Button premium -->
    <style name="Widget.App.PremiumCta" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="cornerRadius">28dp</item>
        <item name="rippleColor">@color/ripple_soft</item>
    </style>

    <!-- Choice card premium -->
    <style name="Widget.App.ChoiceCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">0dp</item>
        <item name="android:backgroundTint">@color/card_background</item>
    </style>

</resources>
