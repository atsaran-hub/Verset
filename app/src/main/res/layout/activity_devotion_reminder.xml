<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_premium_light_hero">

    <!-- Back premium (pill) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/backPill"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="@color/card_background"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Premium badge -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/premiumBadge"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="@color/card_background"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_star"
                app:tint="@color/accent_primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/premium"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:textSize="12sp"
                android:textColor="@color/text_primary"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom area (fade + CTA) -->
    <LinearLayout
        android:id="@+id/bottomArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_fade_soft"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="22dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/textReassurance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/premium_reassurance"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:letterSpacing="0.01"
            android:alpha="0.9"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonEnable"
            style="@style/Widget.App.PremiumCta"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:text="@string/devotion_enable"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@null"
            app:iconTint="@null" />
    </LinearLayout>

    <!-- Scroll content -->
    <ScrollView
        android:id="@+id/scrollRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/backPill"
        app:layout_constraintBottom_toTopOf="@id/bottomArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="22dp">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="220dp"
                android:layout_height="3dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"
                android:max="100"
                android:progress="60"
                app:indicatorColor="@color/accent_primary"
                app:trackColor="@color/track_ultra_soft" />

            <!-- Hero -->
            <FrameLayout
                android:layout_width="260dp"
                android:layout_height="220dp"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_aura_premium" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="210dp"
                    android:layout_height="210dp"
                    android:layout_gravity="center"
                    android:backgroundTint="@color/card_background"
                    app:cardCornerRadius="34dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border_soft">

                    <ImageView
                        android:id="@+id/imageMascotte"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/mascot"
                        android:scaleType="fitCenter"
                        android:src="@drawable/mascotte" />
                </com.google.android.material.card.MaterialCardView>

            </FrameLayout>

            <View
                android:layout_width="46dp"
                android:layout_height="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_accent_pill_premium" />

            <TextView
                android:id="@+id/textTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/devotion_title"
                android:textSize="30sp"
                android:lineSpacingExtra="6dp"
                android:letterSpacing="0.01"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/textSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/devotion_subtitle"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="18dp" />

            <!-- Days card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/daysCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/card_background"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_border_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/devotion_days_label"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:text="@string/devotion_days_hint"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:alpha="0.9" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/daysWrap"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="6dp"
                        android:paddingBottom="2dp">

                        <androidx.constraintlayout.helper.widget.Flow
                            android:id="@+id/daysFlow"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            app:constraint_referenced_ids="chipMon,chipTue,chipWed,chipThu,chipFri,chipSat,chipSun"
                            app:flow_wrapMode="aligned"
                            app:flow_maxElementsWrap="4"
                            app:flow_horizontalGap="12dp"
                            app:flow_verticalGap="12dp"
                            app:flow_horizontalStyle="packed"
                            app:flow_verticalStyle="packed"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <!-- 7 chips : wrap_content (taille selon contenu) -->
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMon"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Mon"
                            android:checkable="true"
                            android:includeFontPadding="false"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:letterSpacing="0.02"
                            app:checkedIconVisible="false"
                            app:ensureMinTouchTargetSize="false"
                            app:chipCornerRadius="22dp"
                            app:chipStartPadding="16dp"
                            app:chipEndPadding="16dp"
                            app:textStartPadding="0dp"
                            app:textEndPadding="0dp"
                            app:chipStrokeWidth="1dp"
                            app:chipStrokeColor="@color/card_border_soft"
                            app:chipBackgroundColor="@color/background_secondary"
                            app:rippleColor="@color/track_ultra_soft" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTue"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Tue"
                            android:checkable="true"
                            android:includeFontPadding="false"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:letterSpacing="0.02"
                            app:checkedIconVisible="false"
                            app:ensureMinTouchTargetSize="false"
                            app:chipCornerRadius="22dp"
                            app:chipStartPadding="16dp"
                            app:chipEndPadding="16dp"
                            app:textStartPadding="0dp"
                            app:textEndPadding="0dp"
                            app:chipStrokeWidth="1dp"
                            app:chipStrokeColor="@color/card_border_soft"
                            app:chipBackgroundColor="@color/background_secondary"
                            app:rippleColor="@color/track_ultra_soft" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipWed"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Wed"
                            android:checkable="true"
                            android:includeFontPadding="false"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:letterSpacing="0.02"
                            app:checkedIconVisible="false"
                            app:ensureMinTouchTargetSize="false"
                            app:chipCornerRadius="22dp"
                            app:chipStartPadding="16dp"
                            app:chipEndPadding="16dp"
                            app:textStartPadding="0dp"
                            app:textEndPadding="0dp"
                            app:chipStrokeWidth="1dp"
                            app:chipStrokeColor="@color/card_border_soft"
                            app:chipBackgroundColor="@color/background_secondary"
                            app:rippleColor="@color/track_ultra_soft" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipThu"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Thu"
                            android:checkable="true"
                            android:includeFontPadding="false"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:letterSpacing="0.02"
                            app:checkedIconVisible="false"
                            app:ensureMinTouchTargetSize="false"
                            app:chipCornerRadius="22dp"
                            app:chipStartPadding="16dp"
                            app:chipEndPadding="16dp"
                            app:textStartPadding="0dp"
                            app:textEndPadding="0dp"
                            app:chipStrokeWidth="1dp"
                            app:chipStrokeColor="@color/card_border_soft"
                            app:chipBackgroundColor="@color/background_secondary"
                            app:rippleColor="@color/track_ultra_soft" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipFri"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Fri"
                            android:checkable="true"
                            android:includeFontPadding="false"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:letterSpacing="0.02"
                            app:checkedIconVisible="false"
                            app:ensureMinTouchTargetSize="false"
                            app:chipCornerRadius="22dp"
                            app:chipStartPadding="16dp"
                            app:chipEndPadding="16dp"
                            app:textStartPadding="0dp"
                            app:textEndPadding="0dp"
                            app:chipStrokeWidth="1dp"
                            app:chipStrokeColor="@color/card_border_soft"
                            app:chipBackgroundColor="@color/background_secondary"
                            app:rippleColor="@color/track_ultra_soft" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSat"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Sat"
                            android:checkable="true"
                            android:includeFontPadding="false"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:letterSpacing="0.02"
                            app:checkedIconVisible="false"
                            app:ensureMinTouchTargetSize="false"
                            app:chipCornerRadius="22dp"
                            app:chipStartPadding="16dp"
                            app:chipEndPadding="16dp"
                            app:textStartPadding="0dp"
                            app:textEndPadding="0dp"
                            app:chipStrokeWidth="1dp"
                            app:chipStrokeColor="@color/card_border_soft"
                            app:chipBackgroundColor="@color/background_secondary"
                            app:rippleColor="@color/track_ultra_soft" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSun"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Sun"
                            android:checkable="true"
                            android:includeFontPadding="false"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:letterSpacing="0.02"
                            app:checkedIconVisible="false"
                            app:ensureMinTouchTargetSize="false"
                            app:chipCornerRadius="22dp"
                            app:chipStartPadding="16dp"
                            app:chipEndPadding="16dp"
                            app:textStartPadding="0dp"
                            app:textEndPadding="0dp"
                            app:chipStrokeWidth="1dp"
                            app:chipStrokeColor="@color/card_border_soft"
                            app:chipBackgroundColor="@color/background_secondary"
                            app:rippleColor="@color/track_ultra_soft" />

                    </androidx.constraintlayout.widget.ConstraintLayout>





                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Time card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/timeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/card_background"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_border_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/devotion_time_label"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:text="@string/devotion_time_hint"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:alpha="0.9" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/timeRow"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:backgroundTint="@color/background_secondary"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/card_border_soft">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp">

                            <TextView
                                android:id="@+id/textTime"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="08:00"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary"/>

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/text_secondary"/>
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/textHelper"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/devotion_helper"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginTop="12dp"
                        android:alpha="0.95"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="22dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
