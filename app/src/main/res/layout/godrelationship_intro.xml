<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_premium_light_hero"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <!-- Soft top gradient (premium atmosphere) -->
    <View
        android:id="@+id/topSoftGradient"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_top_soft_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Aura behind mascot -->
    <View
        android:id="@+id/softAura"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginTop="74dp"
        android:background="@drawable/bg_soft_aura_premium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Mascot -->
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:contentDescription="@string/mascot"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="@id/softAura"
        app:layout_constraintBottom_toBottomOf="@id/softAura"
        app:layout_constraintStart_toStartOf="@id/softAura"
        app:layout_constraintEnd_toEndOf="@id/softAura"
        app:srcCompat="@drawable/mascotte" />

    <!-- Accent pill -->
    <View
        android:id="@+id/accentLine"
        android:layout_width="42dp"
        android:layout_height="6dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_accent_pill_premium"
        app:layout_constraintTop_toBottomOf="@id/softAura"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Title -->
    <TextView
        android:id="@+id/textTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Now let’s talk about\nyour relationship with God"
        android:textColor="@color/text_primary"
        android:textSize="30sp"
        android:lineSpacingExtra="6dp"
        android:letterSpacing="0.01"
        android:fontFamily="serif"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/accentLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/textSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="A few quick questions to better understand where you are spiritually — so we can personalize your daily verses and prayer reminders."
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/textTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- CTA -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonContinue"
        style="@style/Widget.App.PremiumCta"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginBottom="30dp"
        android:text="Continue"
        android:letterSpacing="0.02"
        app:backgroundTint="@null"
        app:iconTint="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
