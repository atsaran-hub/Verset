<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <!-- Back (FIXE en haut) -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back_black"
        android:contentDescription="Back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Zone du bas FIXE (note + CTA) -->
    <LinearLayout
        android:id="@+id/bottomArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Bottom note -->
        <TextView
            android:id="@+id/txtBottomNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel anytime in Google Play."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="10dp" />

        <!-- CTA button -->
        <Button
            android:id="@+id/btnTryNow"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:text="Try now for €0.00"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/accent_primary"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="8dp"
            app:cornerRadius="34dp" />
    </LinearLayout>

    <!-- Contenu scrollable (entre Back et bottomArea) -->
    <ScrollView
        android:id="@+id/scrollRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintBottom_toTopOf="@id/bottomArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/premiumRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Un peu d'air comme les autres pages -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

            <!-- Mascotte / Illustration -->
            <ImageView
                android:id="@+id/imgPremium"
                android:layout_width="wrap_content"
                android:layout_height="471dp"
                android:layout_marginBottom="24dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/mascotte" />

            <!-- Title -->
            <TextView
                android:id="@+id/txtPremiumTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enjoy 3 days of Premium\njust for you"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="16dp" />

            <!-- Reassurance line -->
            <TextView
                android:id="@+id/txtNoPayment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ No payment due now"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <!-- Petit espace bas pour respirer (le bas est fixe) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
