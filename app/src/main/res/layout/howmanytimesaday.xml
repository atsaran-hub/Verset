<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_premium_light_hero">

    <!-- Back pill -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/backPill"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/card_border"
        android:backgroundTint="@color/card_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom CTA -->
    <LinearLayout
        android:id="@+id/bottomArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="10dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_bottom_fade_soft"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonContinue"
            style="@style/Widget.App.PremiumCta"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:text="Continue"
            android:letterSpacing="0.02"
            app:backgroundTint="@null"
            app:iconTint="@null" />
    </LinearLayout>

    <!-- Scroll content -->
    <ScrollView
        android:id="@+id/scrollRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/backPill"
        app:layout_constraintBottom_toTopOf="@id/bottomArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp">

            <!-- Progress (compatible) -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="220dp"
                android:layout_height="5dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp"
                android:max="100"
                android:progress="80"
                app:indicatorColor="@color/accent_primary"
                app:trackColor="#E9EEF8" />

            <!-- Aura + Mascot -->
            <FrameLayout
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_aura_premium"/>

                <ImageView
                    android:id="@+id/imageMascotte"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:contentDescription="Mascot"
                    android:scaleType="fitCenter"
                    android:src="@drawable/mascotte" />
            </FrameLayout>

            <!-- Accent line -->
            <View
                android:layout_width="42dp"
                android:layout_height="6dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_accent_pill_premium" />

            <!-- Title -->
            <TextView
                android:id="@+id/textTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How many verses would you like each day?"
                android:textSize="24sp"
                android:lineSpacingExtra="4dp"
                android:letterSpacing="0.01"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <!-- Subtitle (pricing clarity) -->
            <TextView
                android:id="@+id/textSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 verse is free. More verses are available with Premium."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:lineSpacingExtra="5dp"
                android:layout_marginBottom="14dp" />

            <!-- 1 verse (FREE) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/option1"
                style="@style/Widget.App.ChoiceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="✅ 1 verse"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/badgeFree"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FREE"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_badge_soft_free"
                        android:layout_marginEnd="10dp"/>

                    <ImageView
                        android:id="@+id/check1"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="Selected"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#C9D3E6" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2 verses (PREMIUM) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/option2"
                style="@style/Widget.App.ChoiceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔒 2 verses"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/badge2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PREMIUM"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_badge_soft_premium"
                        android:layout_marginEnd="10dp"/>

                    <ImageView
                        android:id="@+id/check2"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="Selected"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#C9D3E6" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3 verses (PREMIUM) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/option3"
                style="@style/Widget.App.ChoiceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔒 3 verses"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/badge3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PREMIUM"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_badge_soft_premium"
                        android:layout_marginEnd="10dp"/>

                    <ImageView
                        android:id="@+id/check3"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="Selected"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#C9D3E6" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4 verses (PREMIUM) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/option4"
                style="@style/Widget.App.ChoiceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔒 4 verses"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/badge4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PREMIUM"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_badge_soft_premium"
                        android:layout_marginEnd="10dp"/>

                    <ImageView
                        android:id="@+id/check4"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="Selected"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#C9D3E6" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5 verses (PREMIUM) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/option5"
                style="@style/Widget.App.ChoiceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔒 5 verses"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/badge5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PREMIUM"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_badge_soft_premium"
                        android:layout_marginEnd="10dp"/>

                    <ImageView
                        android:id="@+id/check5"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="Selected"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#C9D3E6" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="90dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
