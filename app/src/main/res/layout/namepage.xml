<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_premium_light_hero">

    <!-- Back premium (pill) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/backPill"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/card_border"
        android:backgroundTint="@color/card_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom area (fade + CTA) -->
    <LinearLayout
        android:id="@+id/bottomArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="10dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_bottom_fade_soft"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonGetStarted"
            style="@style/Widget.App.PremiumCta"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:text="@string/continue_btn"
            android:letterSpacing="0.02"
            app:backgroundTint="@null"
            app:iconTint="@null" />
    </LinearLayout>

    <!-- Scroll content -->
    <ScrollView
        android:id="@+id/scrollRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/backPill"
        app:layout_constraintBottom_toTopOf="@id/bottomArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="10dp"
            android:paddingBottom="18dp">

            <!-- Progress premium (plus fin + track très soft) -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="220dp"
                android:layout_height="5dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="18dp"
                android:max="100"
                android:progress="20"
                app:indicatorColor="@color/accent_primary"
                app:trackColor="@color/track_ultra_soft" />

            <!-- Aura + Mascotte (un peu plus compact) -->
            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_soft_aura_premium"/>

                <ImageView
                    android:id="@+id/imageMascotte"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/mascot"
                    android:scaleType="fitCenter"
                    android:src="@drawable/mascotte" />
            </FrameLayout>

            <!-- Accent line -->
            <View
                android:layout_width="42dp"
                android:layout_height="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_accent_pill_premium" />

            <!-- Title -->
            <TextView
                android:id="@+id/textTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/name_title"
                android:textSize="28sp"
                android:lineSpacingExtra="5dp"
                android:letterSpacing="0.01"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Subtitle (un poil plus petit + plus premium) -->
            <TextView
                android:id="@+id/textSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/name_subtitle"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:lineSpacingExtra="5dp"
                android:layout_marginBottom="18dp" />

            <!-- Input premium (1 seul contour, pas de double stroke) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/inputCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/card_border_soft"
                android:backgroundTint="@color/card_background">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    app:boxBackgroundMode="none"
                    app:hintTextColor="@color/text_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/name_hint"
                        android:inputType="textPersonName"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="16sp"
                        android:singleLine="true"
                        android:padding="16dp"
                        android:background="@android:color/transparent" />
                </com.google.android.material.textfield.TextInputLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Helper (plus discret + mieux espacé) -->
            <TextView
                android:id="@+id/textHelper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/name_helper"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="14dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="14dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
