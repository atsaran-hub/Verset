<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <!-- 🌤️ Dégradé très doux en haut (premium) -->

    <!-- ✨ “Aura” douce derrière la mascotte (bleu + or subtil) -->
    <View
        android:id="@+id/topSoftGradient"
        android:layout_width="407dp"
        android:layout_height="914dp"
        android:background="@drawable/bg_top_soft_gradient"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Mascotte -->

    <!-- Petite “pill” d’accent (bleu confiance) -->
    <View
        android:id="@+id/softAura"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginTop="76dp"
        android:background="@drawable/bg_soft_aura"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="170dp"
        android:layout_height="170dp"
        android:contentDescription="@string/app_name"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="@id/softAura"
        app:layout_constraintEnd_toEndOf="@id/softAura"
        app:layout_constraintHorizontal_bias="0.488"
        app:layout_constraintStart_toStartOf="@id/softAura"
        app:layout_constraintTop_toTopOf="@id/softAura"
        app:layout_constraintVertical_bias="0.522"
        app:srcCompat="@drawable/mascotte" />

    <View
        android:id="@+id/accentLine"
        android:layout_width="44dp"
        android:layout_height="6dp"
        android:background="@drawable/bg_accent_pill_premium"
        app:layout_constraintTop_toBottomOf="@id/softAura"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="22dp"/>

    <!-- Titre premium -->
    <TextView
        android:id="@+id/textTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Un moment de paix,\njuste pour toi"
        android:textColor="@color/text_primary"
        android:textSize="32sp"
        android:lineSpacingExtra="6dp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/accentLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Sous-titre (plus premium, plus respirant) -->
    <TextView
        android:id="@+id/textSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="Des versets choisis pour apaiser ton cœur,\nchaque jour, en quelques minutes."
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/textTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dots premium -->

    <!-- CTA premium (dégradé + ombre douce) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonGetStarted"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="Commencer mon moment"
        android:textAllCaps="false"
        android:textColor="@color/button_text"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_button_premium"
        android:elevation="0dp"
        app:cornerRadius="28dp"
        app:rippleColor="@color/selection_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="30dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
