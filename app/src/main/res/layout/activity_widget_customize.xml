<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back_black"
            android:contentDescription="@string/back"
            app:tint="@color/text_primary"/>

        <TextView
            android:id="@+id/topTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/customize_widget"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="10dp"/>

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/skip"
            android:textSize="14sp"
            android:textColor="@color/accent_primary"
            android:paddingStart="10dp"
            android:paddingEnd="6dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>
    </LinearLayout>

    <!-- Bottom CTA -->
    <LinearLayout
        android:id="@+id/bottomArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        android:background="@drawable/bg_bottom_fade_soft"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:text="@string/save"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:backgroundTint="@color/accent_primary"
            app:cornerRadius="28dp"/>

        <TextView
            android:id="@+id/txtStep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 6 OF 8"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.08"
            android:layout_marginTop="10dp"/>
    </LinearLayout>

    <!-- Scroll content -->
    <ScrollView
        android:id="@+id/scrollRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="10dp"
            android:paddingBottom="18dp">
            <View
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/background_primary"/>



            <!-- Headline -->
            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/a_verse_on_your_home_screen"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/keep_gods_word_in_sight"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="14dp"/>

            <!-- Preview card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/card_border_soft"
                android:backgroundTint="@color/card_background"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PREVIEW"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.10"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="10dp"/>

                    <include
                        android:id="@+id/widgetPreviewInclude"
                        layout="@layout/include_widget_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/widgetPreviewNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/preview_note"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- APPEARANCE -->
            <TextView
                android:id="@+id/labelAppearance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APPEARANCE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"/>

            <!-- Light / Dark -->
            <LinearLayout
                android:id="@+id/appearanceRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/optionLight"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border_soft"
                    android:backgroundTint="@color/card_background"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/light"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/optionDark"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/card_border_soft"
                    android:backgroundTint="@color/card_background"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/dark"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- THEME (✅ un seul labelTheme) -->
            <TextView
                android:id="@+id/labelTheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THEME"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp"/>

            <HorizontalScrollView
                android:id="@+id/themeScroller"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never">

                <LinearLayout
                    android:id="@+id/themeRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="6dp">

                    <!-- DAWN -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/themeCardDawn"
                        android:layout_width="120dp"
                        android:layout_height="150dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/card_border_soft"
                        android:backgroundTint="@color/card_background"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/themeThumbDawn"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/theme_thumb_dawn"
                                android:contentDescription="Dawn" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_theme_thumb_overlay"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dawn"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:textColor="@color/white"
                                android:layout_gravity="bottom|start"
                                android:layout_marginStart="12dp"
                                android:layout_marginBottom="12dp"/>

                            <View
                                android:id="@+id/themeSelDawn"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_theme_selected_ring"
                                android:visibility="gone"/>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_theme_thumb_overlay" />
                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- SEA -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/themeCardSea"
                        android:layout_width="120dp"
                        android:layout_height="150dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/card_border_soft"
                        android:backgroundTint="@color/card_background"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/themeThumbSea"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/theme_thumb_sea"
                                android:contentDescription="Sea" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sea"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:textColor="@color/white"
                                android:layout_gravity="bottom|start"
                                android:layout_marginStart="12dp"
                                android:layout_marginBottom="12dp"/>

                            <View
                                android:id="@+id/themeSelSea"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_theme_selected_ring"
                                android:visibility="gone"/>
                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- MIRROR -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/themeCardMirror"
                        android:layout_width="120dp"
                        android:layout_height="150dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/card_border_soft"
                        android:backgroundTint="@color/card_background"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/themeThumbMirror"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/theme_thumb_mirror"
                                android:contentDescription="Mirror" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_theme_thumb_overlay" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mirror"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:textColor="@color/white"
                                android:layout_gravity="bottom|start"
                                android:layout_marginStart="12dp"
                                android:layout_marginBottom="12dp"/>

                            <View
                                android:id="@+id/themeSelMirror"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_theme_selected_ring"
                                android:visibility="gone"/>
                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="28dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
