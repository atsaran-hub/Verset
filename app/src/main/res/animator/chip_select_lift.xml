<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- État sélectionné -->
    <item android:state_checked="true">
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="150"
                android:valueFrom="0dp"
                android:valueTo="4dp"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>

            <objectAnimator
                android:propertyName="scaleX"
                android:duration="150"
                android:valueFrom="1"
                android:valueTo="1.05"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>

            <objectAnimator
                android:propertyName="scaleY"
                android:duration="150"
                android:valueFrom="1"
                android:valueTo="1.05"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>
        </set>
    </item>

    <!-- État pressé -->
    <item android:state_pressed="true">
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="80"
                android:valueFrom="0dp"
                android:valueTo="2dp"/>

            <objectAnimator
                android:propertyName="scaleX"
                android:duration="80"
                android:valueFrom="1"
                android:valueTo="0.97"/>

            <objectAnimator
                android:propertyName="scaleY"
                android:duration="80"
                android:valueFrom="1"
                android:valueTo="0.97"/>
        </set>
    </item>

    <!-- État normal (retour) -->
    <item>
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="150"
                android:valueFrom="4dp"
                android:valueTo="0dp"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>

            <objectAnimator
                android:propertyName="scaleX"
                android:duration="150"
                android:valueFrom="1.05"
                android:valueTo="1"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>

            <objectAnimator
                android:propertyName="scaleY"
                android:duration="150"
                android:valueFrom="1.05"
                android:valueTo="1"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>
        </set>
    </item>

</selector>
